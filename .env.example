# ─────────────────────────────────────────
# Quant Trading Platform – Environment Config
# Copy to .env and fill in your values
# ─────────────────────────────────────────

# Gemini API (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (create at https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Alerts (Gmail App Password recommended)
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_TO=recipient@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Twilio SMS (optional – https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+0987654321

# Webhook (Slack, Discord, custom endpoint)
WEBHOOK_URL=https://hooks.slack.com/services/your_webhook_path

# Trading Config
DEFAULT_CAPITAL=10000
MAX_DAILY_LOSS_PCT=0.05
MAX_POSITION_PCT=0.02
SCAN_INTERVAL=300

# Dashboard
SECRET_KEY=change_this_to_a_random_secret

# Clerk Auth — https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Stripe Payments — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
BASE_URL=https://apollo-quant-trading.vercel.app

# GitHub — for cloud backtest via GitHub Actions
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Required permission: Actions (Read and Write) on this repo
GITHUB_PAT=your_github_pat_here
GITHUB_REPO=Apolloat2022/Apollo-quant-trading

# Upstash Redis — required for Vercel deployment and GitHub Actions scanner
# Get these from: console.upstash.com → your database → REST API section
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
